# =====================================================================
# Deep Research — environment template
# Copy this file to .env and fill in your own keys. DO NOT commit .env
# =====================================================================

# --- Required for L0-L5 ---
# Get key: https://www.firecrawl.dev (free tier: 500 scrapes/month)
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Required for L1-L5 (Tavily MCP) ---
# Get key: https://tavily.com (free tier: 1000 searches/month)
# Configure your Tavily MCP server in ~/.claude.json — this env var is
# used only by scripts that call Tavily directly.
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional for L2-L5 (Codex CLI cross-model channel) ---
# Codex CLI auths via `codex auth login` — no env var needed.
# Requires ChatGPT Pro subscription ($200/month) for GPT-5.4.
# Install: https://developers.openai.com/codex/cli
